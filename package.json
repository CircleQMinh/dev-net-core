    "build:framework": "react-router build --config vite.framework.config.ts && tsc -p tsconfig.framework.json",
    "lint": "eslint .",
    "test:content-route-data": "node --test shared/content/loadContentRouteData.test.mjs",
    "test:seo": "node --test shared/seo/*.test.mjs",
    "validate:framework": "node scripts/validate-framework-build.mjs",
    "preview": "vite preview",
    "preview:framework": "node scripts/preview-framework.mjs"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@hookform/resolvers": "^5.2.2",
    "@mui/icons-material": "^7.3.7",
    "@mui/material": "^7.3.7",
    "@reduxjs/toolkit": "^2.11.2",
    "axios": "1.16.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.71.1",
    "react-markdown": "^10.1.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "7.18.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@react-router/dev": "7.18.0",
    "@react-router/node": "7.18.0",
    "@react-router/serve": "7.18.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "react-router": "7.18.0",
    "tailwindcss": "^4.3.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4"
  }
